generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String    @id @default(uuid()) @db.Uuid
  fullName               String
  email                  String    @unique
  password               String
  phoneNumber            String?
  profilePictureUrl      String?
  profilePicturePublicId String?
  role                   UserRole  @default(PLAYER)
  createdAt              DateTime  @default(now())      @db.Timestamptz(3)
  updatedAt              DateTime  @updatedAt           @db.Timestamptz(3)
  deletedAt              DateTime?                      @db.Timestamptz(3)
  bookings               Booking[] @relation("PlayerBookings")
  venue                  Venue?

  @@map("users")
}

model Venue {
  id             String          @id @default(uuid()) @db.Uuid
  venueAdminId   String          @unique @db.Uuid
  name           String
  description    String?
  phoneNumber    String?
  address        String
  city           String
  latitude       Decimal?        @db.Decimal(10, 8)
  longitude      Decimal?        @db.Decimal(11, 8)
  bankName       String
  accountHolder  String
  accountNumber  String
  createdAt      DateTime        @default(now())      @db.Timestamptz(3)
  updatedAt      DateTime        @updatedAt           @db.Timestamptz(3)
  deletedAt      DateTime?                            @db.Timestamptz(3)
  courts         Court[]
  operatingHours OperatingHour[]
  facilities     VenueFacility[]
  images         VenueImage[]
  venueAdmin     User            @relation(fields: [venueAdminId], references: [id])

  @@map("venues")
}

model OperatingHour {
  id        String    @id @default(uuid()) @db.Uuid
  venueId   String    @db.Uuid
  dayOfWeek DayOfWeek
  openTime  DateTime  @db.Time(6)
  closeTime DateTime  @db.Time(6)
  isClosed  Boolean   @default(false)
  venue     Venue     @relation(fields: [venueId], references: [id])

  @@unique([venueId, dayOfWeek])
  @@map("operating_hours")
}

model VenueImage {
  id           String   @id @default(uuid()) @db.Uuid
  venueId      String   @db.Uuid
  imageUrl     String
  publicId     String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())       @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt            @db.Timestamptz(3)
  venue        Venue    @relation(fields: [venueId], references: [id])

  @@map("venue_images")
}

model Facility {
  id     String          @id @default(uuid()) @db.Uuid
  name   String          @unique
  icon   String?
  description String?
  venues VenueFacility[]

  @@map("facilities")
}

model VenueFacility {
  venueId    String   @db.Uuid
  facilityId String   @db.Uuid
  facility   Facility @relation(fields: [facilityId], references: [id])
  venue      Venue    @relation(fields: [venueId], references: [id])

  @@id([venueId, facilityId])
  @@map("venue_facilities")
}

model Court {
  id           String      @id @default(uuid()) @db.Uuid
  venueId      String      @db.Uuid
  name         String
  sportType    SportType
  pricePerHour Decimal     @db.Decimal(12, 2)
  status       CourtStatus @default(AVAILABLE)
  createdAt    DateTime    @default(now())      @db.Timestamptz(3)
  updatedAt    DateTime    @updatedAt           @db.Timestamptz(3)
  bookings     Booking[]
  venue        Venue       @relation(fields: [venueId], references: [id])

  @@unique([venueId, name])
  @@map("courts")
  @@index([venueId])
}

model Booking {
  id                   String        @id @default(uuid()) @db.Uuid
  bookingCode          String        @unique
  playerId             String        @db.Uuid
  courtId              String        @db.Uuid
  startDatetime        DateTime      @db.Timestamptz(3)
  endDatetime          DateTime      @db.Timestamptz(3)
  pricePerHour         Decimal       @db.Decimal(12, 2)
  totalPrice           Decimal       @db.Decimal(12, 2)
  paymentProofUrl      String?
  paymentProofPublicId String?
  paymentDeadline      DateTime?     @db.Timestamptz(3)
  rejectReason         String?
  status               BookingStatus @default(PENDING_PAYMENT)
  createdAt            DateTime      @default(now())    @db.Timestamptz(3)
  updatedAt            DateTime      @updatedAt         @db.Timestamptz(3)
  court                Court         @relation(fields: [courtId], references: [id])
  player               User          @relation("PlayerBookings", fields: [playerId], references: [id])

  @@index([courtId, startDatetime])
  @@index([playerId, createdAt])
  @@index([status])
  @@index([startDatetime])
  @@index([status, createdAt])
  @@map("bookings")
}

enum UserRole {
  PLAYER
  VENUE_ADMIN
}

enum SportType {
  BADMINTON
  FUTSAL
  BASKET
  MINI_SOCCER
  TENNIS
  PADEL
}

enum CourtStatus {
  AVAILABLE
  MAINTENANCE
  INACTIVE
}

enum BookingStatus {
  PENDING_PAYMENT
  WAITING_VERIFICATION
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}
